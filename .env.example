# TikTok Monitor - 环境变量配置模板（推荐）
# 复制此文件为 .env 并填入你的配置信息
# 注意：.env 文件已加入 .gitignore，不会被提交到版本控制系统
#
# 📖 详细配置指南：请查阅 SETUP_GUIDE.md

# ==================== OpenAI API 配置 ====================
# 从 https://platform.openai.com/api-keys 获取你的 API Key
OPENAI_API_KEY=your-api-key-here

# 如果使用第三方代理，填入代理地址
# 官方 API: 留空或注释掉
# 第三方代理: https://your-proxy.com/v1
OPENAI_API_BASE=

# ==================== 代理配置 ====================
# 如果需要代理访问 TikTok，取消注释并填入代理地址
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ==================== 日志配置 ====================
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ==================== 其他配置 ====================
# 数据库路径（留空则使用默认路径）
# DB_PATH=

# 抓取策略：yt-dlp 或 playwright
# SCRAPER_STRATEGY=yt-dlp

# 自动抓取间隔（小时）
# FETCH_INTERVAL=1.0
